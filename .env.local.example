# Supabase — project URL / anon key (browser) / service role (server only)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cron — Friday invoice reminder to dispatchers (Vercel Cron: Authorization: Bearer CRON_SECRET)
CRON_SECRET=

# Mapbox overlays (dispatcher / driver tooling)
NEXT_PUBLIC_MAPBOX_TOKEN=

# Google Dispatch Sheet — workbook "Alpha Freight Network Website"
# Share: Anyone with the link → Viewer
GOOGLE_DISPATCH_SHEET_ID=
GOOGLE_DISPATCH_SHEET_USE_MONTH_TAB=true
# GOOGLE_DISPATCH_SHEET_TAB=June 2026
GOOGLE_DISPATCH_SHEET_GID=0
GOOGLE_CARRIER_SHEET_TAB=Carriers
# Add more month tabs: GOOGLE_DISPATCH_SHEET_MONTH_GIDS={"January 2027":"1234567890"}
# GOOGLE_DISPATCH_SHEET_CSV_URL=

# ── SMTP — general site mail (contact form, auth alerts, freight onboarding) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=alphaassistant.alpha@gmail.com
SMTP_PASS=
SMTP_FROM=Alpha Solutions <alphaassistant.alpha@gmail.com>

# ── Invoice SMTP — carrier invoice send only (separate Gmail account) ──
DISPATCH_INVOICE_SMTP_HOST=smtp.gmail.com
DISPATCH_INVOICE_SMTP_PORT=587
DISPATCH_INVOICE_SMTP_SECURE=false
DISPATCH_INVOICE_SMTP_USER=invoice.payment.alpha@gmail.com
DISPATCH_INVOICE_SMTP_PASS=
DISPATCH_INVOICE_FROM=Alpha Invoice & Payment <invoice.payment.alpha@gmail.com>

