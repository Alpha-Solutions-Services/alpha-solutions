# Supabase — project URL / anon key (browser) / service role (server only)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe tuition + payouts
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MONTHLY_PRICE_ID=
STRIPE_LIFETIME_PRICE_ID=

# Mapbox overlays (dispatcher / driver tooling)
NEXT_PUBLIC_MAPBOX_TOKEN=

# Google Dispatch Sheet — workbook "Alpha Freight Network Website"
# Share: Anyone with the link → Viewer
# Find ID in URL: docs.google.com/spreadsheets/d/{SHEET_ID}/edit
GOOGLE_DISPATCH_SHEET_ID=
# Monthly tabs named like "June 2026" (auto-selected by current month)
GOOGLE_DISPATCH_SHEET_USE_MONTH_TAB=true
# Override active tab (optional)
# GOOGLE_DISPATCH_SHEET_TAB=June 2026
# Fallback gid until monthly tab exists (first tab = 0)
GOOGLE_DISPATCH_SHEET_GID=0
# Carrier roster tab name in the same workbook
GOOGLE_CARRIER_SHEET_TAB=Carriers
# Or carrier tab gid if tab name export fails
# GOOGLE_CARRIER_SHEET_GID=
# Or full CSV export URL (overrides SHEET_ID)
# GOOGLE_DISPATCH_SHEET_CSV_URL=

# Dispatch invoice PDF (Friday billing — matches Alpha Solutions template)
# DISPATCH_INVOICE_CONTACT_NAME=Muhammad Mikran
# DISPATCH_INVOICE_COMPANY_NAME=Alpha Solutions Services LLC
# DISPATCH_INVOICE_ADDRESS_LINE1=7533 S Center View Ct Ste R, West Jordan, UT
# DISPATCH_INVOICE_ADDRESS_LINE2=84084 US
# DISPATCH_INVOICE_ZELLE_NUMBER=+1 (908) 848-9815
# DISPATCH_INVOICE_ZELLE_NAME=Suzy Agon
# DISPATCH_INVOICE_WEBSITE=https://www.alphasolutions.software/

# FMCSA QCMobile Carrier lookup
FMCSA_API_KEY=

# Login / signup email alerts (SMTP_* required). Ops inbox defaults to alphaassistant.alpha@gmail.com if unset.
# Comma-separated list to notify multiple addresses.
AUTH_OPS_NOTIFY_EMAIL=alphaassistant.alpha@gmail.com
# Set to false to stop sending the copy to the end user (ops emails still send).
AUTH_NOTIFY_USER_EMAIL=true

# SMTP (reuse website contact infra — same SMTP_* vars as contact form)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Alpha Freight <noreply@yourdomain.com>"
CONTACT_EMAIL=info@alphasolutions.software

# Operational mailboxes referenced in onboarding copy / templates
FREIGHT_SUPPORT_EMAIL=freight@alphasolutions.software
FREIGHT_TEAM_EMAIL=

# Canonical marketing URL served from Vercel/Netlify
# Local dev MUST include scheme, e.g. http://localhost:3001 — not just localhost:3001
NEXT_PUBLIC_SITE_URL=http://localhost:3000
