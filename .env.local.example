# Supabase — project URL / anon key (browser) / service role (server only)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe tuition + payouts
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MONTHLY_PRICE_ID=
STRIPE_LIFETIME_PRICE_ID=

# Mapbox overlays (dispatcher / driver tooling)
NEXT_PUBLIC_MAPBOX_TOKEN=

# FMCSA QCMobile Carrier lookup
FMCSA_API_KEY=

# Login / signup email alerts (SMTP_* required). Ops inbox defaults to alphaassistant.alpha@gmail.com if unset.
# Comma-separated list to notify multiple addresses.
AUTH_OPS_NOTIFY_EMAIL=alphaassistant.alpha@gmail.com
# Set to false to stop sending the copy to the end user (ops emails still send).
AUTH_NOTIFY_USER_EMAIL=true

# SMTP (reuse website contact infra — same SMTP_* vars as contact form)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Alpha Freight <noreply@yourdomain.com>"
CONTACT_EMAIL=info@alphasolutions.software

# Operational mailboxes referenced in onboarding copy / templates
FREIGHT_SUPPORT_EMAIL=freight@alphasolutions.software
FREIGHT_TEAM_EMAIL=

# Canonical marketing URL served from Vercel/Netlify
# Local dev MUST include scheme, e.g. http://localhost:3001 — not just localhost:3001
NEXT_PUBLIC_SITE_URL=http://localhost:3000
